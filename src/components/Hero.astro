---

---

<section class="relative flex min-h-[90vh] flex-col overflow-hidden pt-20">
  <div class="absolute inset-0 z-0">
    <img
      src="/hero_img.png"
      alt="Italian kitchen with fresh ingredients"
      class="h-full w-full object-cover"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/30 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto flex w-full max-w-[1400px] flex-1 items-end justify-between px-6 pb-16 pt-8 lg:px-12"
  >
    <div class="max-w-xl">
      <h1
        class="font-serif text-[96px] font-normal leading-[0.95] text-white"
        style="letter-spacing: -2px;"
      >
        Italian Cooking<br />taught by<br /><span class="text-[#FF961E]">Nonnas</span>
      </h1>

      <p
        class="mt-8 font-sans text-lg font-normal leading-[1.2] text-white/90"
      >
        Not Chefs.<br />Not food blogs.<br />The real thing.
      </p>

      <a
        href="#pricing"
        class="group mt-10 inline-flex items-center gap-2 rounded-full border-2 border-primary bg-primary px-8 py-2 font-sans text-base font-bold text-white transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:bg-transparent hover:text-primary active:translate-y-0"
      >
        Cook with a Nonna
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:translate-x-1"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <div class="hidden rounded-xl border border-white/30 bg-white/20 p-5 backdrop-blur-md lg:block">
      <div class="flex flex-col gap-4 text-left">
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Nonnas on the platform
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            40
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Traditional Recipes
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            100+
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            anana cooking community
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            1,265+
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

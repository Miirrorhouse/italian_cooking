---
import lilianaImg from "../../assets/nonnas/lillian_nonna.png";
import annaImg from "../../assets/nonnas/anna_nonna.png";
import isideImg from "../../assets/nonnas/iside_nonna.png";
---

<section class="relative flex min-h-[90vh] flex-col overflow-hidden pt-20">
  <div class="absolute inset-0 z-0">
    <img
      src="/hero_img.png"
      alt="Italian kitchen with fresh ingredients"
      class="hidden h-full w-full object-cover lg:block"
      loading="eager"
    />
    <img
      src="/hero_mobile_img.png"
      alt="Italian kitchen with fresh ingredients"
      class="h-full w-full object-cover lg:hidden"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/30 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto flex w-full max-w-[1400px] flex-1 items-end justify-between px-6 pb-6 pt-8 lg:pb-16 lg:px-12"
  >
    <div class="w-full max-w-xl">
      <div class="hero-animate mb-4 inline-flex items-center gap-2 rounded-full border border-white/30 bg-white/15 px-4 py-2 backdrop-blur-md lg:hidden" style="animation-delay: 0.1s;">
        <span class="h-[6px] w-[6px] flex-shrink-0 rounded-full bg-[#FF961E]"></span>
        <span class="text-sm font-bold text-white">40</span>
        <span class="text-sm text-white/80">Nonnas on the platform</span>
      </div>

      <div class="hero-animate mb-6 inline-flex items-center gap-3 rounded-full bg-white/95 py-2 pl-2 pr-5 backdrop-blur-sm" style="animation-delay: 0.15s;">
        <div class="flex -space-x-3">
          <img src={lilianaImg.src} alt="Home cook" class="h-10 w-10 rounded-full border-2 border-white object-cover" />
          <img src={annaImg.src} alt="Home cook" class="h-10 w-10 rounded-full border-2 border-white object-cover" />
          <img src={isideImg.src} alt="Home cook" class="h-10 w-10 rounded-full border-2 border-white object-cover" />
        </div>
        <div class="flex flex-col">
          <div class="flex gap-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-4 w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-4 w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-4 w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-4 w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-4 w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="text-sm font-semibold text-zinc-800">4.9/5 from 1K+ home cooks</span>
        </div>
      </div>

      <h1
        class="hero-animate font-serif text-[48px] font-normal leading-[0.95] text-white sm:text-[64px] lg:text-[96px]"
        style="letter-spacing: -1px; animation-delay: 0.2s;"
      >
        Learn the recipes<br />the world is<br /><span class="italic text-[#FFD95F]">losing</span>
      </h1>

      <p
        class="hero-animate mt-8 font-sans text-lg font-normal leading-[1.2] text-white/90"
        style="animation-delay: 0.35s;"
      >
        Step inside the kitchens of real Italian grandparents.<br />Learn the techniques, the instincts, and the stories<br />behind the dishes.
      </p>

      <a
        href="https://www.cookwithanana.com/signup"
        class="hero-animate group mt-10 inline-flex w-full items-center justify-center gap-2 rounded-full border-2 border-primary bg-primary px-8 py-2 font-sans text-base font-bold text-white transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:border-white hover:bg-white hover:text-dark active:translate-y-0 sm:w-auto sm:justify-start"
        style="animation-delay: 0.5s;"
      >
        Cook with a Nonna
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:translate-x-1"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

    </div>

    <div class="hidden rounded-xl border border-white/30 bg-white/20 p-5 backdrop-blur-md lg:block">
      <div class="flex flex-col gap-4 text-left">
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Nonnas on the platform
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            40
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Traditional Recipes
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            100+
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            anana cooking community
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            1,265+
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

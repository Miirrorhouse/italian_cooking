---
import socialImg1 from "../../assets/social images/social_image_1.png";
import socialImg2 from "../../assets/social images/social_image_2.png";
import socialImg3 from "../../assets/social images/social_image_3.png";
import socialImg4 from "../../assets/social images/social_image_4.png";
---

<section class="relative flex min-h-[90vh] flex-col overflow-hidden pt-20">
  <div class="absolute inset-0 z-0">
    <img
      src="/hero_img.png"
      alt="Italian kitchen with fresh ingredients"
      class="hidden h-full w-full object-cover lg:block"
      loading="eager"
    />
    <img
      src="/hero_mobile_img.png"
      alt="Italian kitchen with fresh ingredients"
      class="h-full w-full object-cover lg:hidden"
      loading="eager"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/30 to-transparent"
    >
    </div>
  </div>

  <div
    class="relative z-10 mx-auto flex w-full max-w-[1400px] flex-1 items-end justify-between px-6 pb-6 pt-8 lg:pb-16 lg:px-12"
  >
    <div class="flex w-full max-w-xl flex-col">
      <div class="hero-animate order-2 mb-0 mt-6 inline-flex items-center gap-2 self-start rounded-full bg-white/95 py-1.5 pl-1.5 pr-3 backdrop-blur-sm lg:order-1 lg:mb-6 lg:mt-0 lg:gap-3 lg:py-2 lg:pl-2 lg:pr-5" style="animation-delay: 0.15s;">
        <div class="flex -space-x-2 lg:-space-x-3">
          <img src={socialImg1.src} alt="Home cook" class="h-7 w-7 rounded-full border-2 border-white object-cover lg:h-10 lg:w-10" />
          <img src={socialImg2.src} alt="Home cook" class="h-7 w-7 rounded-full border-2 border-white object-cover lg:h-10 lg:w-10" />
          <img src={socialImg3.src} alt="Home cook" class="h-7 w-7 rounded-full border-2 border-white object-cover lg:h-10 lg:w-10" />
          <img src={socialImg4.src} alt="Home cook" class="h-7 w-7 rounded-full border-2 border-white object-cover lg:h-10 lg:w-10" />
        </div>
        <div class="flex flex-col">
          <div class="flex gap-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-3 w-3 lg:h-4 lg:w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-3 w-3 lg:h-4 lg:w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-3 w-3 lg:h-4 lg:w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-3 w-3 lg:h-4 lg:w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="#EAB308" class="h-3 w-3 lg:h-4 lg:w-4"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          </div>
          <span class="whitespace-nowrap text-xs font-semibold text-zinc-800 lg:text-sm">4.9/5 from 1K+ home cooks</span>
        </div>
      </div>

      <h1
        class="hero-animate order-1 font-serif text-[48px] font-normal leading-[0.95] text-white sm:text-[64px] lg:order-2 lg:text-[96px]"
        style="letter-spacing: -1px; animation-delay: 0.2s;"
      >
        Learn the recipes<br />the world is<br /><span class="italic text-[#FFD95F]">Losing</span>
      </h1>

      <p
        class="hero-animate order-3 mt-8 font-sans text-lg font-normal leading-[1.2] text-white/90"
        style="animation-delay: 0.35s;"
      >
        Step inside the kitchens of real Italian grandparents. Learn the techniques, the instincts, and the stories behind the dishes.
      </p>

      <a
        href="https://www.cookwithanana.com/signup"
        class="hero-animate group order-4 mt-10 inline-flex w-full items-center justify-center gap-2 rounded-full border-2 border-primary bg-primary px-8 py-2 font-sans text-base font-bold text-white transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:border-white hover:bg-white hover:text-dark active:translate-y-0 sm:w-auto sm:justify-start lg:self-start"
        style="animation-delay: 0.5s;"
      >
        Cook with a Nonna
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:translate-x-1"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>

    </div>

    <div class="hidden rounded-xl border border-white/30 bg-white/20 p-5 backdrop-blur-md lg:block">
      <div class="flex flex-col gap-4 text-left">
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Nonnas on the platform
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            40
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            Traditional Recipes
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            100+
          </p>
        </div>
        <div class="h-px w-full shrink-0 bg-white/30" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 items-start">
          <p class="text-[16px] leading-normal tracking-wide text-white/80">
            anana cooking community
          </p>
          <p class="text-[16px] font-bold leading-none tracking-wide text-white">
            1,265+
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

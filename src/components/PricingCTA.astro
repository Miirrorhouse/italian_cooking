---

---

<section
  class="relative overflow-hidden bg-primary py-20 lg:py-28"
  id="pricing"
>
  <img
    src="https://images.unsplash.com/photo-1507048331197-7d4ac70811cf?w=1440&q=70&auto=format"
    alt="Italian kitchen table"
    class="absolute inset-0 h-full w-full object-cover mix-blend-overlay opacity-20"
    loading="lazy"
  />

  <div
    class="relative z-10 mx-auto grid max-w-[1400px] grid-cols-1 gap-12 px-6 lg:grid-cols-2 lg:gap-24 lg:px-12"
  >
    <div class="text-center lg:text-left">
      <h2
        class="font-display text-[28px] leading-[1.1] text-white sm:text-4xl lg:text-[50px]"
        data-animate
      >
        You've Spent $6<br />on Less. Trust Us.
      </h2>
      <p
        class="mx-auto mt-6 max-w-md text-base leading-relaxed text-white/90 lg:mx-0"
      >
        anana is $6 a month — that's full access to every Nonna, every recipe,
        and every step-by-step video. No hidden fees. No nonsense. Cancel
        anytime.
      </p>
      <a
        href="#"
        class="mt-10 hidden items-center justify-center rounded-full border-2 border-yellow bg-yellow px-8 py-2 font-sans text-base font-bold text-dark transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:bg-yellow-warm hover:border-yellow-warm active:translate-y-0 lg:inline-flex"
      >
        Get Inside an Italian Kitchen
      </a>
    </div>

    <div class="space-y-5">
      <div
        class="relative overflow-hidden rounded-2xl bg-[#5D82E8] p-5 shadow-lg"
      >
        <div
          class="relative grid gap-8 text-center lg:grid-cols-2 lg:items-center lg:gap-12 lg:text-left"
        >
          <div class="text-center lg:text-left">
            <span
              class="mb-4 inline-flex rounded-full bg-yellow px-3 py-1 font-sans text-sm font-bold text-text-primary"
            >
              Save 24%
            </span>
            <p
              class="font-sans text-xs font-bold uppercase tracking-[0.12em] text-yellow lg:text-sm"
            >
              Annual – Best Value
            </p>
            <p class="mt-3 font-sans text-5xl font-bold leading-none text-white lg:text-6xl">
              $55
            </p>
            <p class="mt-3 font-sans text-base text-white/95">
              Per year · $4.58 a month
            </p>
          </div>

          <div
            class="flex flex-col items-center justify-center text-center lg:items-end lg:justify-center lg:text-right"
          >
            <p
              class="font-sans text-base font-medium leading-snug text-white"
            >
              Full access<br />to everything
            </p>
          </div>
        </div>
      </div>

      <div
        class="flex flex-col items-center gap-4 rounded-2xl bg-blue-soft/75 p-5 text-center backdrop-blur-sm lg:flex-row lg:items-center lg:justify-between lg:text-left"
      >
        <div class="order-2 space-y-1 text-center lg:order-1 lg:text-left">
          <p class="text-5xl font-bold text-white">$9</p>
          <p class="text-base text-white/80">per month</p>
          <p class="text-base text-white/60">billed monthly</p>
        </div>
        <div class="order-1 text-center lg:order-2 lg:text-right">
          <p class="text-base font-bold text-white">
            Monthly plan
          </p>
          <p class="text-base text-white/60">Cancel anytime</p>
        </div>
      </div>

      <div class="flex justify-center pt-1 lg:hidden">
        <a
          href="#"
          class="inline-flex items-center justify-center rounded-full border-2 border-yellow bg-yellow px-8 py-2 font-sans text-base font-bold text-dark transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:bg-yellow-warm hover:border-yellow-warm active:translate-y-0"
        >
          Get Inside an Italian Kitchen
        </a>
      </div>
    </div>
  </div>
</section>

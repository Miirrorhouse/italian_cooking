---
const features = [
  {
    title: "New Recipes every Friday",
    description: "A fresh dish or a fresh Nonna added every Friday.",
    icon: "M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z",
  },
  {
    title: "100+ member only recipes",
    description: "Unlock the full library the moment you subscribe",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
  },
  {
    title: "Step-by-step GIFs",
    description: "Every technique shown visually exactly as the nonna does it",
    icon: "M15 10l4.553-2.069A1 1 0 0121 8.845v6.31a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z",
  },
  {
    title: "The story behind each dish",
    description: "Meet the nonna, her kitchen, her village, and why she makes it this way",
    icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
  },
  {
    title: "No ads, ever",
    description: "Just you, a nonna, and dinner.",
    icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  },
];
---

<section class="bg-white py-6 lg:py-12" id="recipes">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
    <div class="grid gap-12 lg:grid-cols-2 lg:gap-24">
      <div>
        <p
          class="badge"
          data-animate
        >
          The Dish
        </p>
        <h2
          class="mt-4 font-serif text-[36px] font-semibold leading-[1.05] text-text-primary lg:text-[56px]"
          data-animate data-delay="0.1s"
        >
          Anyone can write<br />a recipe. Only a<br />Nonna knows<br />how it
          tastes
        </h2>

        <div class="mt-10 flex items-start gap-3" data-animate data-delay="0.2s">
          <div class="mt-1 h-10 w-[3px] flex-shrink-0 rounded-full bg-primary">
          </div>
          <p class="text-base leading-relaxed text-text-secondary">
            Nonna Ada has been making papassini every Sunday for 44 years. She
            doesn't measure anything. She doesn't follow a recipe. She just
            knows.
          </p>
        </div>

        <ul
          class="mt-10 flex max-w-xl list-none flex-col gap-4 p-0"
          aria-label="What you get with anana"
        >
          {
            features.map((item) => (
              <li>
                <div class="flex items-start gap-4 rounded-xl bg-warm-300 px-5 py-4">
                  <div class="mt-0.5 flex h-11 w-11 shrink-0 items-center justify-center rounded-lg bg-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={item.icon}/>
                    </svg>
                  </div>
                  <div class="flex min-w-0 flex-1 flex-col gap-1 text-left font-sans">
                    <p class="text-[16px] font-bold text-text-primary">
                      {item.title}
                    </p>
                    <p class="text-[14px] font-normal leading-snug text-text-secondary">
                      {item.description}
                    </p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>

        <div class="mt-8">
          <div class="border-t border-warm-500/50 pt-4 flex flex-col items-center">
            <a
              href="#pricing"
              class="group inline-flex items-center gap-2 rounded-full border-2 border-primary bg-primary px-8 py-2 font-sans text-base font-bold text-white transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:bg-transparent hover:text-primary active:translate-y-0"
            >
              Cook with a Nonna
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:translate-x-1"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
            <p class="mt-3 text-[12px] text-text-muted">Try now with full access</p>
          </div>
        </div>
      </div>

      <div class="relative order-first lg:order-last lg:sticky lg:top-24 lg:self-start" data-animate data-delay="0.15s">
        <div class="relative overflow-hidden rounded-xl">
          <img
            src="/anyone_img.png"
            alt="Italian Nonna cooking traditional dish"
            class="h-[300px] w-full object-cover sm:h-[400px] lg:h-[571px]"
            loading="lazy"
          />
          <div
            class="pointer-events-none absolute inset-x-0 bottom-0 h-[45%] bg-gradient-to-t from-black/70 via-black/25 to-transparent"
            aria-hidden="true"
          >
          </div>

          <div
            class="absolute bottom-[18px] left-[18px] z-10 flex max-w-[min(100%,20rem)] flex-col gap-3 text-left"
          >
            <p class="font-serif text-2xl font-semibold leading-tight text-white drop-shadow-sm sm:text-[26px]">
              Nonna Pietruccia
            </p>

            <div class="flex items-center gap-2">
              <div class="flex shrink-0 items-center gap-2 rounded-full border border-white/30 bg-white/20 px-3 py-1.5 backdrop-blur-md">
                <span class="h-2 w-2 shrink-0 rounded-full bg-orange" aria-hidden="true"></span>
                <span class="text-[14px] font-medium text-white">Oliena, Sardinia</span>
              </div>

              <p class="hidden shrink-0 text-[14px] font-bold text-orange sm:block">
                Cooking for 54+ years
              </p>
            </div>

            <p class="text-[14px] font-bold text-orange sm:hidden">
              Cooking for 54+ years
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

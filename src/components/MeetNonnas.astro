---
import lilianaIncollingo from "../../assets/nonnas/lillian_nonna.png";
import annaMoscatelli from "../../assets/nonnas/anna_nonna.png";
import isideRicci from "../../assets/nonnas/iside_nonna.png";
import chiaraPiredda from "../../assets/nonnas/chiara_nonna.png";

const nonnas = [
  {
    name: "Liliana Incollingo",
    location: "Rome, Lazio",
    recipes: 2,
    image: lilianaIncollingo,
  },
  {
    name: "Anna Moscatelli",
    location: "Monterotondo, Lazio",
    recipes: 8,
    image: annaMoscatelli,
  },
  {
    name: "Iside Ricci",
    location: "Bevagna, Umbria",
    recipes: 3,
    image: isideRicci,
  },
  {
    name: "Chiara Piredda",
    location: "Oristano, Sardinia",
    recipes: 1,
    image: chiaraPiredda,
  },
];
---

<section class="bg-white py-16 lg:py-24" id="nonnas">
  <div class="mx-auto max-w-[1400px] px-6 lg:px-12">
    <h2
      class="text-center font-serif text-4xl font-normal leading-[0.93] text-text-primary lg:text-[50px]"
      data-reveal
    >
      Meet the Nonnas<br />Behind the food
    </h2>

    <!-- Mobile marquee -->
    <div class="mt-8 sm:hidden">
      <div class="-mx-6 overflow-hidden">
        <div class="nonnas-marquee-track flex gap-4 px-6">
          {
            [...nonnas, ...nonnas].map((nonna) => (
              <article class="w-[180px] shrink-0 cursor-pointer">
                <div class="relative overflow-hidden rounded-xl bg-warm-300">
                  <img
                    src={nonna.image.src}
                    alt={nonna.name}
                    width={nonna.image.width}
                    height={nonna.image.height}
                    class="h-[240px] w-full object-cover"
                    loading="lazy"
                  />
                  <div
                    class="absolute bottom-3 left-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-white px-3 py-1 text-sm font-normal text-text-primary shadow-[0_2px_10px_rgba(0,0,0,0.12)]"
                    aria-hidden="true"
                  >
                    <svg class="h-4 w-4 shrink-0 text-text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 10c0 3.5 3.6 7 8 7s8-3.5 8-7" />
                      <path d="M6 10V8a6 6 0 0 1 12 0v2" />
                      <path d="M8 14h8" />
                    </svg>
                    <span>{nonna.recipes}</span>
                  </div>
                </div>
                <div class="mt-3 text-center">
                  <h3 class="font-serif text-base font-normal leading-[1.2] text-text-primary">
                    {nonna.name}
                  </h3>
                  <p class="text-[13px] text-text-secondary">{nonna.location}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <div class="mt-8">
        <a
          href="#pricing"
          class="group flex w-full items-center justify-center gap-2 rounded-full border-2 border-primary bg-primary px-8 py-2 font-sans text-base font-bold text-white transition-all duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-px hover:bg-transparent hover:text-primary active:translate-y-0"
        >
          See them all
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-[250ms] [transition-timing-function:cubic-bezier(0.22,1,0.36,1)] group-hover:translate-x-1">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Desktop grid -->
    <div class="mt-12 hidden grid-cols-3 gap-4 sm:grid sm:gap-4 lg:grid-cols-5 lg:gap-6" data-stagger>
      {
        nonnas.map((nonna) => (
          <article class="group cursor-pointer">
            <div class="relative overflow-hidden rounded-xl bg-warm-300">
              <img
                src={nonna.image.src}
                alt={nonna.name}
                width={nonna.image.width}
                height={nonna.image.height}
                class="h-[260px] w-full object-cover transition-transform duration-500 group-hover:scale-105 lg:h-[314px]"
                loading="lazy"
              />
              <div
                class="absolute bottom-3 left-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-white px-3 py-1 text-sm font-normal text-text-primary shadow-[0_2px_10px_rgba(0,0,0,0.12)]"
                aria-hidden="true"
              >
                <svg class="h-4 w-4 shrink-0 text-text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 10c0 3.5 3.6 7 8 7s8-3.5 8-7" />
                  <path d="M6 10V8a6 6 0 0 1 12 0v2" />
                  <path d="M8 14h8" />
                </svg>
                <span>5</span>
              </div>
            </div>
            <div class="mt-3 text-left">
              <h3 class="font-serif text-lg font-normal leading-[1.2] text-text-primary">
                {nonna.name}
              </h3>
              <p class="text-[14px] text-text-secondary">{nonna.location}</p>
            </div>
          </article>
        ))
      }

      <article class="group flex cursor-pointer flex-col">
        <div
          class="relative flex h-[260px] w-full flex-col items-center justify-center rounded-xl bg-blue-accent px-4 lg:h-[314px]"
        >
          <div
            class="absolute bottom-3 left-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-white px-3 py-1 text-sm font-normal text-text-primary shadow-[0_2px_10px_rgba(0,0,0,0.12)]"
            aria-hidden="true"
          >
            <svg class="h-4 w-4 shrink-0 text-text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 10c0 3.5 3.6 7 8 7s8-3.5 8-7" />
              <path d="M6 10V8a6 6 0 0 1 12 0v2" />
              <path d="M8 14h8" />
            </svg>
            <span>5</span>
          </div>

          <p class="font-serif text-5xl font-normal leading-none text-white lg:text-[56px]">
            36+
          </p>

          <p class="mt-2 font-sans text-sm font-medium text-white/90">
            Nonnas Inside
          </p>
          <a
            href="#pricing"
            class="mt-5 inline-flex items-center justify-center rounded-full bg-white px-6 py-2.5 font-sans text-sm font-bold text-primary shadow-sm transition-all hover:bg-warm-100 active:scale-[0.98]"
          >
            See them all
          </a>
        </div>
        <div class="mt-3 text-left">
          <h3 class="font-serif text-lg font-normal leading-[1.2] text-text-primary">
            &amp; many More Nonnas
          </h3>
          <p class="text-[14px] text-text-secondary">From all over Italy</p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  @keyframes nonnas-marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .nonnas-marquee-track {
    animation: nonnas-marquee 16s linear infinite;
    width: max-content;
  }
  .nonnas-marquee-track:hover {
    animation-play-state: paused;
  }
</style>

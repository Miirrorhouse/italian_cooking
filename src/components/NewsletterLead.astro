---

---

<section class="bg-dark-navy" aria-labelledby="newsletter-heading">
  <div class="mx-auto max-w-[1400px] px-6 py-12 lg:px-12 lg:py-16">
    <div class="grid gap-12 lg:grid-cols-[2fr_1fr] lg:items-center lg:gap-32">

      <div class="text-center lg:text-left">
        <p class="font-sans text-[16px] font-medium text-white/95">
          40 nonnas. 100+ recipes. New recipes every Friday
        </p>
        <h3 class="mt-2 font-serif text-[36px] font-normal leading-[1.05] text-white sm:text-[48px] lg:text-[64px]" data-reveal>
          Less than a coffee a month
        </h3>
        <a
          href="https://www.cookwithanana.com/plans"
          class="mt-6 inline-flex items-center justify-center rounded-full bg-primary px-8 py-3.5 font-sans text-base font-bold text-white transition-all hover:bg-primary-hover active:scale-[0.98]"
        >
          Cook with a Nonna
        </a>
        <p class="mt-4 font-sans text-sm text-white/55">
          $55/year · Cancel anytime
        </p>
      </div>

      <div
        class="flex flex-col justify-between gap-8 rounded-3xl bg-primary p-6 text-left shadow-[0_24px_48px_-12px_rgba(23,101,252,0.35)] lg:aspect-square lg:p-7"
      data-reveal
      >
        <div class="flex flex-col gap-4">
          <p
            class="inline-flex w-fit rounded-full border border-white/30 bg-white/15 px-4 py-1.5 font-sans text-[11px] font-bold uppercase tracking-[0.12em] text-white backdrop-blur-sm"
          >
            Free gift
          </p>

          <h2
            id="newsletter-heading"
            class="font-serif text-3xl font-normal leading-tight text-white lg:text-4xl lg:leading-[1.15]"
          >
            Get a free <span class="text-yellow">Nonna Recipe</span> sent to your inbox.
          </h2>

          <p class="font-sans text-base leading-relaxed text-white/90">
            Not sure yet? Start here. One of our most-loved recipes, free —
            straight from Nonna's kitchen to yours.
          </p>
        </div>

        <form
          id="newsletter-form"
          class="flex flex-col gap-3"
          method="post"
          action="#"
        >
          <label class="sr-only" for="newsletter-email">Your email address</label>
          <input
            id="newsletter-email"
            name="email"
            type="email"
            autocomplete="email"
            required
            placeholder="Your email address"
            class="min-h-[48px] w-full flex-1 rounded-full border border-white/70 bg-primary-hover/80 px-5 py-3 font-sans text-base text-white placeholder:text-white/45 outline-none transition-[box-shadow] focus:border-white focus:ring-2 focus:ring-white/35"
          />
          <button
            type="submit"
            class="min-h-[48px] shrink-0 rounded-full bg-yellow px-6 py-3 font-sans text-base font-bold text-dark-navy transition-all hover:bg-yellow-warm active:scale-[0.98] sm:px-8"
          >
            Send me the recipe
          </button>
        </form>

        <script>
          const APPS_SCRIPT_URL =
            'https://script.google.com/a/macros/anana.us/s/AKfycbyFoVCOW2njNU4BAcCRLWpTBNI8UU3J-5WMfSwg4n0ux-dXGWnqkwyJK_o4Dyb7rJPL/exec';

          document.getElementById('newsletter-form')?.addEventListener('submit', async function (e) {
            e.preventDefault();
            const form = document.getElementById('newsletter-form');
            const input = document.getElementById('newsletter-email');
            if (!form || !(input instanceof HTMLInputElement)) return;

            const email = input.value.trim();
            if (!email) return;

            try {
              await fetch(APPS_SCRIPT_URL, {
                method: 'POST',
                mode: 'no-cors',
                headers: { 'Content-Type': 'text/plain;charset=utf-8' },
                body: JSON.stringify({ email }),
              });
              form.outerHTML =
                '<p class="font-sans text-base font-medium text-white">You\'re on the list! We\'ll be in touch.</p>';
            } catch {
              alert('Something went wrong. Try again.');
            }
          });
        </script>
      </div>

    </div>
  </div>
</section>

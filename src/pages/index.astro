---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import SocialProof from "../components/SocialProof.astro";
import TheDish from "../components/TheDish.astro";
import NewsletterLead from "../components/NewsletterLead.astro";
import RecipeCards from "../components/RecipeCards.astro";
import MeetNonnas from "../components/MeetNonnas.astro";
import Testimonials from "../components/Testimonials.astro";
import PricingCTA from "../components/PricingCTA.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
---

<Layout>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <TheDish />
    <NewsletterLead />
    <RecipeCards />
    <MeetNonnas />
    <Testimonials />
    <PricingCTA />
    <FinalCTA />
  </main>
  <Footer />
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
